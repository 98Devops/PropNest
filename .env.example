# PropNest — environment
# Copy to .env and fill in your Supabase project values.
# .env is gitignored — never commit real keys.

VITE_SUPABASE_URL=https://<your-project>.supabase.co
VITE_SUPABASE_ANON_KEY=<your anon/public key>

# Operator/audit scripts (scripts/) use a service_role key set in the SHELL only,
# never in this file or the client bundle:
#   SUPABASE_SERVICE_KEY=...   (export in terminal, clear after use)
